{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/context-bootstrap.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/ts-style-guard.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/import-validator.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/destructive-command-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/block-coauthor.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/block-todowrite.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/post-edit-check.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/pre-stop-verification.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/banned-words-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/verify-grounding.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .codex/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
