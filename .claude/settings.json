{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/context-bootstrap.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/context-injector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/ts-style-guard.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/import-validator.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/ai-antipattern-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/destructive-command-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/block-coauthor.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/block-todowrite.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/post-edit-check.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pre-stop-verification.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/banned-words-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/verify-grounding.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/pre-compact-prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cd \"$(git rev-parse --show-toplevel)\" && .claude/hooks/statusline.sh"
  },
  "permissions": {
    "mode": "default",
    "rules": [
      {
        "tool": "Bash",
        "decision": "deny",
        "if": "Bash(rm -rf|git reset --hard|git push --force|git push -f )",
        "reason": "Destructive commands require explicit user approval"
      },
      {
        "tool": "Read",
        "decision": "allow",
        "reason": "Read-only file access"
      },
      {
        "tool": "Glob",
        "decision": "allow",
        "reason": "Read-only search"
      },
      {
        "tool": "Grep",
        "decision": "allow",
        "reason": "Read-only search"
      },
      {
        "tool": "Bash",
        "decision": "allow",
        "if": "Bash(tsc --noEmit|echo \"no lint configured\"|bun test|git status|git diff|git log|bd *)",
        "reason": "Safe verification and task tracking"
      },
      {
        "tool": "Bash",
        "decision": "ask",
        "if": "Bash(git commit*|git push*)",
        "reason": "Git operations require review"
      },
      {
        "tool": "Edit",
        "decision": "ask",
        "reason": "Code changes require approval"
      },
      {
        "tool": "Write",
        "decision": "ask",
        "reason": "File creation requires approval"
      }
    ]
  }
}
