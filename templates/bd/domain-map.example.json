{
  "$comment": "Domain → directory map. Maps the epic's `domain:` field (dotted path) to one or more directory globs. The pre-create gate uses this to verify children's files[] live under the declared domain. Edit per project; oisin-dev will not overwrite this once present.",

  "auth.sso": ["src/auth/**", "src/server/auth/**"],
  "auth.session": ["src/auth/session/**", "src/middleware/session/**"],
  "obs.sentry": ["src/observability/**", "src/server/error-middleware/**"],
  "obs.logging": ["src/logging/**"],
  "obs.metrics": ["src/metrics/**"],
  "obs.tracing": ["src/tracing/**"],
  "data.schema": ["src/db/schema/**", "drizzle/**", "prisma/**"],
  "data.migrations": ["src/db/migrations/**", "drizzle/migrations/**"],
  "ui.foundation": ["packages/ui/**", "src/components/foundation/**"],
  "ui.forms": ["src/components/forms/**", "src/forms/**"],
  "api.contract": ["packages/contract/**", "packages/api/**", "openapi/**"],
  "api.handlers": ["src/server/handlers/**", "src/api/**"],
  "infra.deploy": ["infra/**", "deploy/**", ".github/workflows/**"]
}
